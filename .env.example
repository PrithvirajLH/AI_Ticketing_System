# Azure AI Foundry
AZURE_AI_FOUNDRY_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
AZURE_AI_FOUNDRY_API_KEY=your-api-key-here
AZURE_AI_FOUNDRY_MODEL=gpt-5.4-mini

# Agent Names (must match what you created in Foundry portal)
INTENT_EXTRACTOR_AGENT_ID=intent-extractor
DEPARTMENT_CLASSIFIER_AGENT_ID=department-classifier
CONFIDENCE_GATE_AGENT_ID=confidence-gate
TICKET_GENERATOR_AGENT_ID=ticket-generator

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NODE_ENV=development
